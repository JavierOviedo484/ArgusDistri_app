[Unit]
Description=ARGUS Distribuidor de Documentos (FastAPI)
After=network.target docker.service

[Service]
Type=simple
User=javi
WorkingDirectory=/home/javi/distribuidor-pdfs/backend
ExecStart=/home/javi/distribuidor-pdfs/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
