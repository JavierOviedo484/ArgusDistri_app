# ─────────────────────────────────────────────────────────────
# ARGUS — Variables de entorno
# Copia a .env y edita los valores sensibles
# ─────────────────────────────────────────────────────────────

# ─── Base de datos ───────────────────────────────────────────
# Para producción con PostgreSQL (descomentar):
# DATABASE_URL=postgresql://argus:argus_secret_2026@argus-db:5432/argus
# Para desarrollo con SQLite (dejar comentado):
# DATABASE_URL=sqlite:///data/argus.db

# ─── WhatsApp (Evolution API) ────────────────────────────────
WHATSAPP_API_URL=http://argus-evo:8080
WHATSAPP_API_KEY=argus-whatsapp-2026
WHATSAPP_INSTANCE=argus

# ─── Email (Gmail SMTP) ─────────────────────────────────────
EMAIL_SENDER=
GMAIL_APP_PASSWORD=

# ─── Autenticación Dashboard ────────────────────────────────
# Si dejas estas vacías, el dashboard NO pide login (útil en local).
# En producción, pon usuario y contraseña FUERTES.
ARGUS_USERNAME=admin
ARGUS_PASSWORD=cambia_esta_contraseña

# ─── Empresa ────────────────────────────────────────────────
EMPRESA_NOMBRE=ARGUS

# ─── Bases de datos internas (PostgreSQL) ───────────────────
ARGUS_DB_PASSWORD=argus_secret_2026
EVO_DB_PASSWORD=evolution_pass_2026
